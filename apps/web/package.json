{
  "name": "@arrcontrol/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-typescript ../../docs/api/openapi.yaml --output src/api/generated.ts",
    "check:api": "openapi-typescript ../../docs/api/openapi.yaml --output src/api/generated.ts --check",
    "build": "pnpm check:api && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "i18next": "25.3.2",
    "lucide-react": "0.525.0",
    "openapi-fetch": "^0.17.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "15.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "1.61.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "9.30.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "7.0.4",
    "vitest": "3.2.4"
  }
}
