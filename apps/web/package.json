{
  "name": "@arrcontrol/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:api": "openapi-typescript ../../docs/api/openapi.yaml --output src/api/generated.ts",
    "check:api": "openapi-typescript ../../docs/api/openapi.yaml --output src/api/generated.ts --check",
    "build": "pnpm check:api && tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "i18next": "26.3.6",
    "lucide-react": "1.24.0",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "17.0.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
