    }
  },
  "App": {
    "PublicUrl": "http://localhost:8080"
  },
  "DataProtection": {
    "KeysPath": ""
  },
  "CredentialEncryption": {
    "Keys": []
  },
  "ReverseProxy": {
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "Automation": {
    "Scheduler": {
      "PollInterval": "00:00:02",
      "PlanningInterval": "00:00:30",
      "MaterializationHorizon": "00:10:00",
