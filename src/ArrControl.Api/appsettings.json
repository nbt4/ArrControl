{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Database": "Host=localhost;Database=arrcontrol;Username=arrcontrol;Password=arrcontrol"
  },
  "Auth": {
    "Local": {
      "AccessTokenLifetime": "00:15:00",
      "RefreshTokenLifetime": "30.00:00:00",
      "LoginFailureWindow": "00:15:00",
      "AccountFailureLimit": 5,
      "IpFailureLimit": 20,
      "LoginRequestLimit": 60,
