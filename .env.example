POSTGRES_DB=arrcontrol
POSTGRES_USER=arrcontrol
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
ARRCONTROL_ADMIN_EMAIL=admin@example.invalid
ARRCONTROL_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ARRCONTROL_AUTH_ACCESS_TOKEN_LIFETIME=00:15:00
ARRCONTROL_AUTH_REFRESH_TOKEN_LIFETIME=30.00:00:00
ARRCONTROL_AUTH_LOGIN_FAILURE_WINDOW=00:15:00
ARRCONTROL_AUTH_ACCOUNT_FAILURE_LIMIT=5
ARRCONTROL_AUTH_IP_FAILURE_LIMIT=20
ARRCONTROL_AUTH_LOGIN_REQUEST_LIMIT=60
ARRCONTROL_AUTH_SESSION_MUTATION_REQUEST_LIMIT=120
ARRCONTROL_OIDC_ENABLED=false
ARRCONTROL_OIDC_AUTHORITY=https://auth.example.com/application/o/arrcontrol/
ARRCONTROL_OIDC_CLIENT_ID=arrcontrol
ARRCONTROL_OIDC_CLIENT_SECRET=CHANGE_ME_OIDC_SECRET
ARRCONTROL_OIDC_ADMIN_GROUP=
ARRCONTROL_MASTER_KEY_FILE=./secrets/arrcontrol-master-key
ARRCONTROL_MASTER_KEY_VERSION=1
ARRCONTROL_DATA_PROTECTION_KEYS_PATH=/var/lib/arrcontrol/data-protection-keys
ARRCONTROL_SCHEDULER_MAX_CONCURRENCY=4
ARRCONTROL_SCHEDULER_MAX_ATTEMPTS=5
ARRCONTROL_AUDIT_RETENTION_DAYS=365
ARRCONTROL_AUDIT_RETENTION_BATCH_SIZE=1000
ARRCONTROL_AUDIT_RETENTION_MAXIMUM_BATCHES=10
# Direct HTTP supports status/UI only; browser login needs the HTTPS proxy documented in docs/DEVELOPMENT.md.
ARRCONTROL_PUBLIC_URL=http://localhost:8080
