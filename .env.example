# Production image: pin a version; use `latest` only to evaluate new builds.
ARRCONTROL_IMAGE=nobentie/arrcontrol:1.0.0

# Persistent data on the Docker host.
ARRCONTROL_DATA_DIR=/opt/docker/arrcontrol
ARRCONTROL_MASTER_KEY_FILE=/opt/docker/arrcontrol/secrets/master-key

# Generate long random values. Never commit your real .env file.
ARRCONTROL_DB_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_DATABASE_PASSWORD
ARRCONTROL_ADMIN_EMAIL=admin@example.com
ARRCONTROL_ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_ADMIN_PASSWORD

# The public HTTPS address configured in your reverse proxy.
ARRCONTROL_PUBLIC_URL=https://arrcontrol.example.com
